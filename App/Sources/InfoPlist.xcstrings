          }
        }
      }
    },
    "NSSiriUsageDescription" : {
      "comment" : "Info.plist · Siri permission prompt · Calm, plainspoken, single sentence. Shown when Siri is first invoked for App Intents.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mit Siri kannst du in Dawny freihändig neue Aufgaben anlegen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dawny lets you add tasks hands-free with Siri."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dawny te permite añadir tareas con manos libres usando Siri."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dawny vous permet d’ajouter des tâches mains libres avec Siri."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Con Siri puoi aggiungere attività in Dawny senza usare le mani."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siriを使ってDawnyにハンズフリーでタスクを追加できます。"
