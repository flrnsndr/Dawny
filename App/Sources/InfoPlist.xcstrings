    "NSRemindersUsageDescription" : {
      "comment" : "Info.plist · Reminders permission prompt · Calm, plainspoken, single sentence. Explains why we need Reminders access. Shown the first time we sync a task.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dawny synchronisiert deine Aufgaben für heute mit der Erinnerungen-App."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dawny syncs your daily focus tasks with Apple Reminders."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dawny sincroniza las tareas de tu foco diario con Recordatorios."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dawny synchronise vos tâches du jour avec l’app Rappels."
          }
        },
