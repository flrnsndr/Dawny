    "welcome.page2.body" : {
      "comment" : "Welcome · Onboarding page 2 body · Plain sentence describing the Backlog.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schreib alles auf — ohne Zeitdruck. Dein Backlog vergisst nichts."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drop tasks in without deadline pressure. Your backlog never forgets."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anota todo sin presión de fechas. Tu Backlog no olvida nada."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notez tout, sans pression d’échéance. Votre Backlog n’oublie rien."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aggiungi tutto senza la pressione delle scadenze. Il tuo Backlog non dimentica nulla."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "締め切りに追われず、思いついたものを全部入れて。バックログは忘れません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "마감에 쫓기지 말고 떠오르는 모든 걸 적어두세요. 백로그는 잊지 않아요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anote tudo sem pressão de prazo. Seu Backlog não esquece nada."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "把一切都丢进来，不必担心截止日期。待办清单不会遗忘。"
          }
        }
      }
    },
    "welcome.page2.title" : {
