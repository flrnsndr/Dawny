    "welcome.page4.body" : {
      "comment" : "Welcome · Onboarding page 4 body · Plain sentence describing the daily reset.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was du nicht geschafft hast, wandert über Nacht zurück ins Backlog. Morgen ist ein neuer Anfang."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anything left undone slides back to the backlog overnight. Tomorrow is a clean slate."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lo que no termines vuelve al Backlog por la noche. Mañana empiezas con la mesa limpia."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce qui n’est pas terminé retourne au Backlog pendant la nuit. Demain, place nette."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quel che resta da fare torna nel Backlog durante la notte. Domani si riparte da zero."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "終わらなかったタスクは、夜のうちにバックログへ戻ります。明日はまっさらな一日。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "마치지 못한 일은 밤사이 백로그로 돌아갑니다. 내일은 새로 시작이에요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O que ficar pendente volta ao Backlog durante a noite. Amanhã começa do zero."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "今天没完成的事会在夜里悄悄回到待办清单，让明天有个干净的开始。"
          }
        }
      }
    },
