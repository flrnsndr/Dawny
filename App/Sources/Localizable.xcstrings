    "welcome.page1.body" : {
      "comment" : "Welcome · Onboarding page 1 body · Warm, conversational, single sentence. Source string passed via LocalizedStringResource defaultValue.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine To-do-Liste, die jeden Morgen frisch erwacht — frei vom Ballast von gestern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your to-do list that wakes up fresh every morning, free from yesterday’s clutter."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu lista de tareas que amanece nueva cada mañana, sin el desorden de ayer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre liste de tâches qui repart à zéro chaque matin, sans le désordre de la veille."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La tua lista di cose da fare che ogni mattina si sveglia pulita, senza il disordine di ieri."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "毎朝すっきりとリセットされる、昨日の雑念を残さないToDoリスト。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "어제의 어수선함을 털어내고 매일 아침 깔끔하게 시작하는 할 일 목록이에요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sua lista de tarefas que amanhece em ordem todo dia, sem a bagunça de ontem."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "每天清晨从零开始的待办清单，让昨天的杂事不再打扰你。"
          }
        }
      }
    },
