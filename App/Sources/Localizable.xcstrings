    "welcome.page1.body" : {
      "comment" : "Welcome · Onboarding page 1 body · Warm, conversational, single sentence. Source string passed via LocalizedStringResource defaultValue.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deine To-do-Liste, die jeden Morgen frisch erwacht — frei vom Ballast von gestern."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your to-do list that wakes up fresh every morning, free from yesterday’s clutter."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu lista de tareas que amanece nueva cada mañana, sin el desorden de ayer."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sua lista de tarefas que amanhece em ordem todo dia, sem a bagunça de ontem."
          }
        }
      }
    },
    "welcome.page1.title" : {
      "comment" : "Welcome · Onboarding page 1 title · Friendly greeting headline.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Willkommen bei Dawny"
          }
