        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reúna tudo no seu Backlog"
          }
        }
      }
    },
    "welcome.page3.body" : {
      "comment" : "Welcome · Onboarding page 3 body · Plain sentence about Daily Focus.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Entscheide jeden Morgen, was wirklich zählt — und zieh es zu „Heute“."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Each morning, decide what truly matters and pull it into Today."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cada mañana decide qué importa de verdad y muévelo a Hoy."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toda manhã, escolha o que realmente importa e leve para Hoje."
          }
        }
      }
    },
    "welcome.page3.title" : {
      "comment" : "Welcome · Onboarding page 3 title · Headline.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Den Tag bewusst planen"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Plan today on purpose"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Planifica el día con intención"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Planeje o dia com propósito"
          }
        }
      }
    },
    "welcome.page4.body" : {
      "comment" : "Welcome · Onboarding page 4 body · Plain sentence describing the daily reset.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Was du nicht geschafft hast, wandert über Nacht zurück ins Backlog. Morgen ist ein neuer Anfang."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anything left undone slides back to the backlog overnight. Tomorrow is a clean slate."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lo que no termines vuelve al Backlog por la noche. Mañana empiezas con la mesa limpia."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O que ficar pendente volta ao Backlog durante a noite. Amanhã começa do zero."
          }
        }
      }
