        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welcome to Dawny"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Te damos la bienvenida a Dawny"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Boas-vindas ao Dawny"
          }
        }
      }
    },
    "welcome.page2.body" : {
      "comment" : "Welcome · Onboarding page 2 body · Plain sentence describing the Backlog.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schreib alles auf — ohne Zeitdruck. Dein Backlog vergisst nichts."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drop tasks in without deadline pressure. Your backlog never forgets."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anota todo sin presión de fechas. Tu Backlog no olvida nada."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Anote tudo sem pressão de prazo. Seu Backlog não esquece nada."
          }
        }
      }
    },
    "welcome.page2.title" : {
      "comment" : "Welcome · Onboarding page 2 title · Headline.",
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alles im Backlog sammeln"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Capture everything in your Backlog"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reúnelo todo en tu Backlog"
          }
