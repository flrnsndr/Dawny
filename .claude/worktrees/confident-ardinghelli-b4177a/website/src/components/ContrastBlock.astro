---
import { type Lang, getDict } from "@/i18n";
import SunMark from "@/components/SunMark.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = getDict(lang);
---

<section
  id="contrast"
  class="relative bg-gradient-to-b from-[var(--color-paper)] to-[#eef2f7] text-[var(--color-ink)] py-32 sm:py-44"
>
  <SunMark />

  <div class="container-content relative z-10">
    <div class="max-w-3xl mb-20">
      <p class="reveal text-xs font-medium uppercase tracking-[0.18em] text-[var(--color-ink-soft)]/70 mb-6">
        <span class="inline-block h-px w-8 bg-[var(--color-ink-soft)]/40 align-middle mr-3"></span>
        {dict.contrast.eyebrow}
      </p>
      <h2 class="reveal text-display text-[clamp(2rem,5vw,4rem)]">
        <span class="block text-[var(--color-ink)]/80">{dict.contrast.title}</span>
        <span class="block">{dict.contrast.titleAccent}</span>
      </h2>
    </div>

    <div class="reveal grid gap-3 md:grid-cols-2 md:gap-0 rounded-3xl overflow-hidden border border-black/5 bg-white shadow-[0_30px_80px_-40px_rgba(14,26,46,0.25)]">
      <div class="contrast-col contrast-col--left">
        <div class="contrast-col-head">
          <span class="contrast-dot bg-[#e0524d]"></span>
          <span>{dict.contrast.leftLabel}</span>
        </div>
        <ul>
          {dict.contrast.rows.map((row) => (
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#c84843" stroke-width="2.4" aria-hidden="true">
                <path d="M18 6L6 18M6 6l12 12"/>
              </svg>
              <span>{row.left}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="contrast-col contrast-col--right">
        <div class="contrast-col-head">
          <span class="contrast-dot bg-[var(--color-dawn)]"></span>
          <span>{dict.contrast.rightLabel}</span>
        </div>
        <ul>
          {dict.contrast.rows.map((row) => (
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-dawn)" stroke-width="2.4" aria-hidden="true">
                <path d="M5 12l5 5L20 7"/>
              </svg>
              <span>{row.right}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .contrast-col {
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .contrast-col {
      padding: 2.5rem 2.25rem;
    }
  }

  .contrast-col--left {
    background: linear-gradient(180deg, rgba(224, 82, 77, 0.04) 0%, transparent 100%);
  }

  .contrast-col--right {
    background: linear-gradient(180deg, rgba(245, 176, 66, 0.06) 0%, transparent 100%);
    border-top: 1px solid rgba(0, 0, 0, 0.05);
  }

  @media (min-width: 768px) {
    .contrast-col--right {
      border-top: none;
      border-left: 1px solid rgba(0, 0, 0, 0.05);
    }
  }

  .contrast-col-head {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-ink-soft);
    padding-bottom: 1rem;
    border-bottom: 1px dashed rgba(14, 26, 46, 0.1);
  }

  .contrast-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .contrast-col ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contrast-col li {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    color: var(--color-ink);
    font-size: 1.0625rem;
    line-height: 1.45;
  }

  .contrast-col li svg {
    flex-shrink: 0;
    margin-top: 0.225rem;
  }

  .contrast-col--left li {
    color: var(--color-ink-soft);
  }
</style>
