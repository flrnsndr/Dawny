---
/**
 * SunMark — gestalteter Sonnenmarker mit weichem Atmosphären-Halo.
 *
 * Pattern (wichtig für flüssige Übergänge zwischen Sektionen):
 *   - Die Elternsektion MUSS `position: relative` haben.
 *   - Die Elternsektion DARF KEIN `overflow: hidden` haben, sonst wird der
 *     Atmosphären-Halo an der Sektionsgrenze hart abgeschnitten und ein
 *     sichtbarer „Naht"-Streifen entsteht (der Sun-Halo kann dann nicht mehr
 *     in angrenzende Sektionen hineinbleedn).
 *   - Der Inhaltscontainer der Sektion sollte `position: relative z-10`
 *     haben, damit Text/Elemente oberhalb des Halos bleiben.
 *   - Horizontales Clipping der Seite übernimmt `<body>` global
 *     (`overflow-x: hidden` in global.css) — das reicht, um horizontales
 *     Scrollen zu verhindern, ohne vertikale Überlappung zu blockieren.
 *   - Für gezielte Eindämmung (z. B. damit ein warmer Halo NICHT in eine
 *     dunkle Nachtsektion bleedt) kann eine Sektion gezielt `overflow-hidden`
 *     behalten (siehe Reset, FinalCTA).
 */
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<div class={`sun-mark ${className}`} aria-hidden="true">
  <div class="sun-mark-atmosphere"></div>
  <div class="sun-mark-glow"></div>
  <div class="sun-mark-disc"></div>
  <div class="sun-mark-ring"></div>
</div>

<style>
  .sun-mark {
    position: absolute;
    left: 50%;
    bottom: 18%;
    transform: translate(-50%, 0);
    width: min(100vw, clamp(280px, 92vw, 720px));
    aspect-ratio: 1 / 1;
    pointer-events: none;
    /* Positiver z-index ist entscheidend: nur so landet der Halo im CSS-Paint-Step
       NACH allen Sektions-Backgrounds. Bei z-index 0 würden angrenzende Sektions-
       Backgrounds den überhängenden Halo überschreiben. */
    z-index: 1;
  }

  /* Weiter, sehr weicher atmosphärischer Wash — bleedet in die leeren Sektions-Zonen
     und verbindet benachbarte Sonnen visuell. */
  .sun-mark-atmosphere {
    position: absolute;
    inset: -85%;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(252, 201, 122, 0.35) 0%,
      rgba(245, 176, 66, 0.18) 35%,
      rgba(245, 176, 66, 0.06) 60%,
      transparent 82%
    );
    filter: blur(55px);
    z-index: 0;
  }

  .sun-mark-glow {
    position: absolute;
    inset: -30%;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(252, 201, 122, 0.55) 0%,
      rgba(245, 176, 66, 0.25) 40%,
      transparent 72%
    );
    filter: blur(24px);
    z-index: 1;
  }

  .sun-mark-disc {
    position: absolute;
    inset: 18%;
    border-radius: 50%;
    background: radial-gradient(
      circle at 35% 35%,
      #ffe1a8 0%,
      #f5b042 55%,
      #d8902a 100%
    );
    box-shadow: 0 0 80px 20px rgba(245, 176, 66, 0.5);
    z-index: 2;
  }

  /* Symmetrischer Highlight: wirkt horizontalkalibriert zur Section-Mitte (Two Lists u. a.). */
  .sun-mark-two-lists .sun-mark-disc {
    background: radial-gradient(
      circle at 50% 38%,
      #ffe1a8 0%,
      #f5b042 55%,
      #d8902a 100%
    );
  }

  .sun-mark-ring {
    position: absolute;
    inset: 16%;
    border-radius: 50%;
    border: 2px solid rgba(252, 201, 122, 0.6);
    box-shadow: inset 0 0 40px rgba(245, 176, 66, 0.4);
    z-index: 3;
  }
</style>
