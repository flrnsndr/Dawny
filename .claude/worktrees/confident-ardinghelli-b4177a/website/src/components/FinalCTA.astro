---
import { type Lang, getDict, TESTFLIGHT_URL } from "@/i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = getDict(lang);
---

<section
  id="join"
  class="relative isolate overflow-hidden text-white"
>
  <div class="cta-bg absolute inset-0 -z-10" aria-hidden="true">
    <div class="cta-stars absolute inset-0">
      <svg viewBox="0 0 1440 600" preserveAspectRatio="xMidYMid slice" class="h-full w-full">
        <g fill="white">
          <circle cx="180" cy="80" r="1" opacity="0.6"/>
          <circle cx="380" cy="140" r="0.8" opacity="0.5"/>
          <circle cx="620" cy="60" r="1.2" opacity="0.7"/>
          <circle cx="900" cy="130" r="0.9" opacity="0.55"/>
          <circle cx="1180" cy="90" r="1.1" opacity="0.65"/>
          <circle cx="1320" cy="180" r="0.7" opacity="0.45"/>
        </g>
      </svg>
    </div>

    <div class="cta-glow" aria-hidden="true"></div>
  </div>

  <div class="container-content relative py-32 sm:py-44 grid gap-12 lg:gap-16 lg:grid-cols-[1.5fr_1fr] items-center">
    <div>
      <p class="reveal text-xs font-medium uppercase tracking-[0.18em] text-[var(--color-dawn-soft)] mb-6">
        {dict.finalCta.eyebrow}
      </p>
      <h2 class="reveal text-display text-white text-[clamp(2.5rem,6vw,5.25rem)] leading-[1.02]">
        <span class="block">{dict.finalCta.title.line1}</span>
        <span class="block">{dict.finalCta.title.line2}</span>
      </h2>
      <p class="reveal mt-8 max-w-lg text-lg sm:text-xl text-white/75 leading-relaxed">
        {dict.finalCta.body}
      </p>

      <div class="reveal mt-10 flex flex-wrap items-center gap-4">
        <a
          href={TESTFLIGHT_URL}
          target="_blank"
          rel="noopener"
          class="btn-primary text-base"
          data-ph-event="testflight_click"
          data-ph-location="final_cta"
          data-ph-target="testflight"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.5 12.5c0-3 2.5-4.4 2.6-4.5-1.4-2-3.6-2.3-4.4-2.4-1.9-.2-3.6 1.1-4.6 1.1-.9 0-2.4-1.1-4-1-2 0-3.9 1.2-5 3-2.1 3.7-.5 9.1 1.5 12.1 1 1.5 2.2 3.1 3.8 3.1 1.5-.1 2.1-1 3.9-1 1.8 0 2.4 1 4 .9 1.6 0 2.7-1.5 3.7-3 1.2-1.7 1.6-3.4 1.7-3.5-.1 0-3.2-1.2-3.2-4.8zM14.6 3.5c.8-1 1.4-2.4 1.2-3.8-1.2 0-2.6.8-3.4 1.8-.8.9-1.5 2.4-1.3 3.7 1.3.1 2.7-.7 3.5-1.7z"/>
          </svg>
          {dict.finalCta.cta}
        </a>
        <span class="text-sm text-white/50">
          {lang === "de" ? "Kostenlos · iOS 26.2+" : "Free · iOS 26.2+"}
        </span>
      </div>
    </div>

    <aside class="reveal hidden lg:flex flex-col items-center gap-4">
      <div class="qr-card">
        <img
          src="/assets/qr-testflight.svg"
          alt={dict.finalCta.qrAlt}
          width="180"
          height="180"
          loading="lazy"
        />
      </div>
      <p class="text-xs uppercase tracking-[0.18em] text-white/45 text-center">
        {lang === "de" ? "Mit iPhone scannen" : "Scan with your iPhone"}
      </p>
    </aside>
  </div>
</section>

<style>
  .cta-bg {
    background:
      radial-gradient(ellipse at 50% 100%, rgba(245, 176, 66, 0.4) 0%, transparent 60%),
      linear-gradient(180deg, #050d20 0%, #0b1733 60%, #142547 100%);
  }

  .cta-glow {
    position: absolute;
    left: 50%;
    bottom: -180px;
    transform: translateX(-50%);
    width: 800px;
    height: 800px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(245, 176, 66, 0.55) 0%, rgba(245, 176, 66, 0.18) 35%, transparent 70%);
    filter: blur(20px);
    animation: glow-pulse 8s ease-in-out infinite;
  }

  .qr-card {
    padding: 1rem;
    border-radius: 20px;
    background: white;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.12),
      0 30px 60px -20px rgba(0, 0, 0, 0.5),
      0 0 60px -20px rgba(245, 176, 66, 0.4);
  }

  .qr-card img {
    width: 180px;
    height: 180px;
    display: block;
  }
</style>
