---
import Base from "@/layouts/Base.astro";
import { type Lang } from "@/i18n";

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    lang: Lang;
    canonicalPath: string;
    altCanonicalPath?: string;
  };
}

const { frontmatter } = Astro.props;
---

<Base
  lang={frontmatter.lang}
  title={`${frontmatter.title} — Dawny`}
  description={frontmatter.description}
  canonicalPath={frontmatter.canonicalPath}
  altCanonicalPath={frontmatter.altCanonicalPath}
>
  <article class="legal-article">
    <div class="container-narrow">
      <p class="legal-eyebrow">
        <a href={`/${frontmatter.lang}/`} class="legal-back">← Dawny</a>
      </p>
      <h1 class="legal-title">{frontmatter.title}</h1>
      <div class="legal-prose">
        <slot />
      </div>
    </div>
  </article>
</Base>

<style is:global>
  .legal-article {
    background: var(--color-paper);
    color: var(--color-ink);
    padding: 8rem 0 6rem;
    min-height: 80vh;
  }

  .legal-eyebrow {
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
    color: var(--color-ink-soft);
  }

  .legal-back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-ink-soft);
    transition: color 200ms;
  }

  .legal-back:hover {
    color: var(--color-ink);
  }

  .legal-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 2.5rem;
  }

  .legal-prose {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-ink-soft);
  }

  .legal-prose h1,
  .legal-prose h2,
  .legal-prose h3 {
    color: var(--color-ink);
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.25;
  }

  .legal-prose h2 {
    font-size: 1.5rem;
  }
  .legal-prose h3 {
    font-size: 1.15rem;
  }

  .legal-prose p,
  .legal-prose ul,
  .legal-prose ol,
  .legal-prose blockquote {
    margin-bottom: 1.1rem;
  }

  .legal-prose ul,
  .legal-prose ol {
    padding-left: 1.5rem;
  }

  .legal-prose li {
    margin-bottom: 0.4rem;
  }

  .legal-prose a {
    color: var(--color-horizon);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .legal-prose a:hover {
    color: var(--color-dawn);
  }

  .legal-prose blockquote {
    border-left: 3px solid var(--color-dawn);
    padding: 0.5rem 0 0.5rem 1.25rem;
    background: rgba(245, 176, 66, 0.06);
    border-radius: 0 8px 8px 0;
    color: var(--color-ink);
  }

  .legal-prose code {
    background: rgba(14, 26, 46, 0.06);
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .legal-prose strong {
    color: var(--color-ink);
  }

  .legal-prose hr {
    margin: 2.5rem 0;
    border: 0;
    border-top: 1px dashed rgba(14, 26, 46, 0.15);
  }
</style>
