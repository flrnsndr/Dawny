---
import { Image } from "astro:assets";
import { type Lang, getDict, GITHUB_URL, CONTACT_EMAIL } from "@/i18n";
import iconLight from "@/assets/icons/dawny-icon-light.png";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = getDict(lang);
const year = new Date().getFullYear();
const rights = dict.footer.rights.replace("{year}", String(year));
const privacyPath = lang === "de" ? "/de/datenschutz/" : "/en/privacy/";
const imprintPath = lang === "de" ? "/de/impressum/" : "/en/imprint/";
---

<footer class="relative bg-[var(--color-night-deep)] text-white/70 pt-20 pb-12 overflow-hidden">
  <div
    class="absolute inset-x-0 -top-px h-px bg-gradient-to-r from-transparent via-white/15 to-transparent"
    aria-hidden="true"
  ></div>

  <div class="container-content grid gap-10 md:grid-cols-[1.4fr_1fr] items-start">
    <div class="space-y-4">
      <div class="flex items-center gap-3">
        <Image
          src={iconLight}
          alt=""
          width={32}
          height={32}
          widths={[32, 64]}
          sizes="32px"
          class="h-8 w-8 rounded-md opacity-90"
          loading="lazy"
        />
        <span class="text-display text-lg text-white">Dawny</span>
      </div>
      <p class="max-w-md text-sm text-white/60 leading-relaxed">
        {dict.footer.tagline}
      </p>
    </div>

    <nav class="text-sm grid grid-cols-2 gap-x-6 gap-y-3" aria-label="Footer">
      <a
        href={privacyPath}
        class="text-white/60 hover:text-white transition-colors"
        data-ph-event="legal_click"
        data-ph-target="privacy"
      >{dict.footer.links.privacy}</a>
      <a
        href={imprintPath}
        class="text-white/60 hover:text-white transition-colors"
        data-ph-event="legal_click"
        data-ph-target="imprint"
      >{dict.footer.links.imprint}</a>
      <a
        href={GITHUB_URL}
        target="_blank"
        rel="noopener"
        class="text-white/60 hover:text-white transition-colors inline-flex items-center gap-1.5"
        data-ph-event="outbound_click"
        data-ph-target="github"
      >
        {dict.footer.links.github}
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M7 17L17 7M17 7H8M17 7v9"/>
        </svg>
      </a>
      <a
        href={`mailto:${CONTACT_EMAIL}`}
        class="text-white/60 hover:text-white transition-colors"
        data-ph-event="outbound_click"
        data-ph-target="mail"
      >{dict.footer.links.mail}</a>
    </nav>
  </div>

  <div class="container-content mt-12 pt-6 border-t border-white/8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 text-xs text-white/40">
    <p>{rights}</p>
    <p class="font-mono">v0.1 · iOS 26.2+</p>
  </div>
</footer>
