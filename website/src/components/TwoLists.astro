---
import { Image } from "astro:assets";
import { type Lang, getDict } from "@/i18n";
import SunMark from "@/components/SunMark.astro";
import backlogImg from "@/assets/screenshots/backlog.png";
import todayOpenImg from "@/assets/screenshots/today-open.png";
import todayProgressImg from "@/assets/screenshots/today-progress.png";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = getDict(lang);
---

<section
  id="how"
  class="relative bg-[var(--color-paper)] text-[var(--color-ink)] py-32 sm:py-44"
>
  <div class="container-content relative z-10">
    <div class="mx-auto mb-20 max-w-2xl md:mx-0 md:text-left text-center">
      <p class="reveal text-xs font-medium uppercase tracking-[0.18em] text-[var(--color-ink-soft)]/70 mb-6">
        <span class="inline-block h-px w-8 bg-[var(--color-ink-soft)]/40 align-middle mr-3"></span>
        {dict.twoLists.eyebrow}
      </p>
      <h2 class="reveal text-display text-[clamp(2rem,5vw,4rem)]">
        {dict.twoLists.title}
      </h2>
    </div>

    <div class="two-lists-visual relative isolate">
      <SunMark class="sun-mark-two-lists sun-anchor-two-lists pointer-events-none" />

      <div
        class="two-lists-grid relative z-10 grid gap-14 lg:grid-cols-3 lg:gap-x-8 xl:gap-x-12 xl:gap-y-14 items-start justify-items-center"
      >
      <div class="reveal two-lists-col flex w-full flex-col items-center justify-self-center text-center">
        <div class="phone-frame mb-8">
          <div class="phone-screen">
            <Image
              src={backlogImg}
              alt={dict.twoLists.captionBacklog}
              loading="lazy"
              widths={[235, 470]}
              sizes="(min-width: 1024px) 22vw, 42vw"
            />
          </div>
          <div class="phone-glow phone-glow-cool" aria-hidden="true"></div>
        </div>
        <span class="two-lists-kicker text-xs font-mono uppercase tracking-[0.18em] mb-3">
          {dict.twoLists.backlogLabel}
        </span>
        <h3 class="text-display text-2xl sm:text-3xl mb-3 max-w-xs">
          {dict.twoLists.backlogText.split("—")[0].trim()}
        </h3>
        <p class="max-w-sm text-[var(--color-ink-soft)] leading-relaxed">
          {dict.twoLists.backlogText.split("—").slice(1).join("—").trim()}
        </p>
      </div>

      <div class="reveal two-lists-col flex w-full flex-col items-center justify-self-center text-center">
        <div class="phone-frame mb-8">
          <div class="phone-screen">
            <Image
              src={todayOpenImg}
              alt={dict.twoLists.captionFocus}
              loading="lazy"
              widths={[235, 470]}
              sizes="(min-width: 1024px) 22vw, 42vw"
            />
          </div>
          <div class="phone-glow phone-glow-warm" aria-hidden="true"></div>
        </div>
        <span class="two-lists-kicker text-xs font-mono uppercase tracking-[0.18em] mb-3">
          {dict.twoLists.focusLabel}
        </span>
        <h3 class="text-display text-2xl sm:text-3xl mb-3 max-w-xs">
          {dict.twoLists.focusText.split("—")[0].trim()}
        </h3>
        <p class="max-w-sm text-[var(--color-ink-soft)] leading-relaxed">
          {dict.twoLists.focusText.split("—").slice(1).join("—").trim()}
        </p>
      </div>

      <div class="reveal two-lists-col flex w-full flex-col items-center justify-self-center text-center">
        <div class="phone-frame mb-8">
          <div class="phone-screen">
            <Image
              src={todayProgressImg}
              alt={dict.twoLists.captionProgress}
              loading="lazy"
              widths={[235, 470]}
              sizes="(min-width: 1024px) 22vw, 42vw"
            />
          </div>
          <div class="phone-glow phone-glow-dual" aria-hidden="true"></div>
        </div>
        <span class="two-lists-kicker text-xs font-mono uppercase tracking-[0.18em] mb-3">
          {dict.twoLists.progressLabel}
        </span>
        <h3 class="text-display text-2xl sm:text-3xl mb-3 max-w-xs">
          {dict.twoLists.progressText.split("—")[0].trim()}
        </h3>
        <p class="max-w-sm text-[var(--color-ink-soft)] leading-relaxed">
          {dict.twoLists.progressText.split("—").slice(1).join("—").trim()}
        </p>
      </div>
    </div>
    </div>
  </div>
</section>

<style>
  .two-lists-kicker {
    color: color-mix(in oklab, var(--color-ink-soft) 82%, var(--color-ink) 18%);
  }

  .phone-frame {
    position: relative;
    width: clamp(200px, 42vw, 280px);
    isolation: isolate;
  }

  @media (min-width: 1024px) {
    .two-lists-grid .phone-frame {
      width: clamp(200px, 22vw, 260px);
    }

    /* Einheitliche Spaltenbreite, damit die mittlere Phone optisch wirklich in der Mitte sitzt */
    .two-lists-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .phone-screen {
    position: relative;
    z-index: 1;
    border-radius: 36px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 0 0 1.5px rgba(14, 26, 46, 0.08),
      0 30px 60px -30px rgba(14, 26, 46, 0.35),
      0 12px 28px -12px rgba(14, 26, 46, 0.18);
    background: white;
    transform: translateZ(0);
    transition: transform 600ms var(--ease-soft, ease);
  }

  .phone-screen img {
    display: block;
    width: 100%;
    height: auto;
  }

  .phone-glow {
    position: absolute;
    inset: -10% -15%;
    z-index: 0;
    border-radius: 50%;
    filter: blur(40px);
    opacity: 0.5;
  }

  .phone-glow-warm {
    background: radial-gradient(circle, rgba(245, 176, 66, 0.4) 0%, transparent 65%);
  }

  .phone-glow-cool {
    background: radial-gradient(circle, rgba(190, 221, 230, 0.55) 0%, transparent 65%);
  }

  .phone-glow-dual {
    background:
      radial-gradient(circle at 30% 40%, rgba(190, 221, 230, 0.35) 0%, transparent 55%),
      radial-gradient(circle at 70% 55%, rgba(245, 176, 66, 0.38) 0%, transparent 60%);
  }

  .phone-frame:hover .phone-screen {
    transform: translateY(-4px);
  }

  /* Sonne relativ zum Phone-Raster (gleicher Breitenkasten wie container-content), nicht zur Section */
  .two-lists-visual {
    width: 100%;
    overflow: visible;
  }

  .two-lists-visual > :global(.sun-anchor-two-lists.sun-mark) {
    left: 50%;
    right: auto;
    transform: translate(-50%, 0);
    bottom: clamp(6%, 12vh, 22%);
  }

  @media (min-width: 1024px) {
    .two-lists-visual > :global(.sun-anchor-two-lists.sun-mark) {
      bottom: 10%;
    }
  }
</style>
