---
import { type Lang, getDict } from "@/i18n";
import SunMark from "@/components/SunMark.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = getDict(lang);
---

<section
  id="how"
  class="relative bg-[var(--color-paper)] text-[var(--color-ink)] py-32 sm:py-44"
>
  <SunMark />

  <div class="container-content relative z-10">
    <div class="max-w-2xl mb-20">
      <p class="reveal text-xs font-medium uppercase tracking-[0.18em] text-[var(--color-ink-soft)]/70 mb-6">
        <span class="inline-block h-px w-8 bg-[var(--color-ink-soft)]/40 align-middle mr-3"></span>
        {dict.twoLists.eyebrow}
      </p>
      <h2 class="reveal text-display text-[clamp(2rem,5vw,4rem)]">
        {dict.twoLists.title}
      </h2>
    </div>

    <div class="grid gap-12 md:gap-8 lg:gap-16 md:grid-cols-2 items-center">
      <div class="reveal flex flex-col items-center text-center md:items-start md:text-left">
        <div class="phone-frame mb-8">
          <div class="phone-screen">
            <img
              src="/assets/screenshots/backlog.png"
              alt={dict.twoLists.captionBacklog}
              width="424"
              height="900"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="phone-glow phone-glow-cool" aria-hidden="true"></div>
        </div>
        <span class="text-xs font-mono uppercase tracking-[0.18em] text-[var(--color-horizon)] mb-3">
          {dict.twoLists.backlogLabel}
        </span>
        <h3 class="text-display text-2xl sm:text-3xl mb-3 max-w-xs">
          {dict.twoLists.backlogText.split("—")[0].trim()}
        </h3>
        <p class="max-w-sm text-[var(--color-ink-soft)] leading-relaxed">
          {dict.twoLists.backlogText.split("—").slice(1).join("—").trim()}
        </p>
      </div>

      <div class="reveal flex flex-col items-center text-center md:items-start md:text-left">
        <div class="phone-frame mb-8">
          <div class="phone-screen">
            <img
              src="/assets/screenshots/today-open.png"
              alt={dict.twoLists.captionFocus}
              width="424"
              height="900"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="phone-glow phone-glow-warm" aria-hidden="true"></div>
        </div>
        <span class="text-xs font-mono uppercase tracking-[0.18em] text-[var(--color-dawn)] mb-3">
          {dict.twoLists.focusLabel}
        </span>
        <h3 class="text-display text-2xl sm:text-3xl mb-3 max-w-xs">
          {dict.twoLists.focusText.split("—")[0].trim()}
        </h3>
        <p class="max-w-sm text-[var(--color-ink-soft)] leading-relaxed">
          {dict.twoLists.focusText.split("—").slice(1).join("—").trim()}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .phone-frame {
    position: relative;
    width: clamp(220px, 60vw, 300px);
    isolation: isolate;
  }

  .phone-screen {
    position: relative;
    z-index: 1;
    border-radius: 36px;
    overflow: hidden;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.6) inset,
      0 0 0 1.5px rgba(14, 26, 46, 0.08),
      0 30px 60px -30px rgba(14, 26, 46, 0.35),
      0 12px 28px -12px rgba(14, 26, 46, 0.18);
    background: white;
    transform: translateZ(0);
    transition: transform 600ms var(--ease-soft, ease);
  }

  .phone-screen img {
    display: block;
    width: 100%;
    height: auto;
  }

  .phone-glow {
    position: absolute;
    inset: -10% -15%;
    z-index: 0;
    border-radius: 50%;
    filter: blur(40px);
    opacity: 0.5;
  }

  .phone-glow-warm {
    background: radial-gradient(circle, rgba(245, 176, 66, 0.4) 0%, transparent 65%);
  }

  .phone-glow-cool {
    background: radial-gradient(circle, rgba(190, 221, 230, 0.55) 0%, transparent 65%);
  }

  .phone-frame:hover .phone-screen {
    transform: translateY(-4px);
  }
</style>
