---
import { type Lang, getDict, TESTFLIGHT_URL } from "@/i18n";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = getDict(lang);
---

<section
  id="hero"
  class="relative text-white"
  data-hero
>
  <div class="hero-sun-layer" aria-hidden="true">
    <div class="hero-sunrise">
      <div class="hero-sunrise-atmosphere"></div>
      <div class="hero-sunrise-glow"></div>
      <div class="hero-sunrise-disc"></div>
      <div class="hero-sunrise-ring"></div>
    </div>
  </div>

  <div class="container-content relative pt-36 sm:pt-44 pb-32 sm:pb-44 min-h-[88svh] flex flex-col justify-center">
    <p class="reveal text-xs sm:text-sm font-medium uppercase tracking-[0.18em] text-white/55 mb-6">
      {dict.hero.eyebrow}
    </p>

    <h1 class="reveal text-display text-white text-[clamp(2.5rem,7vw,5.75rem)] leading-[0.98] max-w-[18ch]">
      {dict.hero.headline.map((line, i) => (
        <span class="block">
          {i === dict.hero.headline.length - 1 ? (
            <span class="text-blend-exclusion-warm">{line}</span>
          ) : (
            line
          )}
        </span>
      ))}
    </h1>

    <p class="reveal mt-8 max-w-xl text-lg sm:text-xl text-white/75 leading-relaxed">
      {Array.isArray(dict.hero.sub)
        ? dict.hero.sub.map((line) => <span class="block">{line}</span>)
        : dict.hero.sub}
    </p>

    <div class="reveal mt-10 flex flex-wrap items-center gap-3">
      <a
        href={TESTFLIGHT_URL}
        target="_blank"
        rel="noopener"
        class="btn-primary"
        data-ph-event="testflight_click"
        data-ph-location="hero"
        data-ph-target="testflight"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.5 12.5c0-3 2.5-4.4 2.6-4.5-1.4-2-3.6-2.3-4.4-2.4-1.9-.2-3.6 1.1-4.6 1.1-.9 0-2.4-1.1-4-1-2 0-3.9 1.2-5 3-2.1 3.7-.5 9.1 1.5 12.1 1 1.5 2.2 3.1 3.8 3.1 1.5-.1 2.1-1 3.9-1 1.8 0 2.4 1 4 .9 1.6 0 2.7-1.5 3.7-3 1.2-1.7 1.6-3.4 1.7-3.5-.1 0-3.2-1.2-3.2-4.8zM14.6 3.5c.8-1 1.4-2.4 1.2-3.8-1.2 0-2.6.8-3.4 1.8-.8.9-1.5 2.4-1.3 3.7 1.3.1 2.7-.7 3.5-1.7z"/>
        </svg>
        {dict.hero.ctaPrimary}
      </a>
      <a href="#manifesto" class="btn-ghost text-white/80" data-ph-event="scroll_to_manifesto" data-ph-location="hero">
        {dict.hero.ctaSecondary}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
          <path d="M12 5v14M19 12l-7 7-7-7"/>
        </svg>
      </a>
    </div>
  </div>

  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 text-white/30 text-xs tracking-widest uppercase flex flex-col items-center gap-2 pointer-events-none">
    <span>scroll</span>
    <span class="block h-8 w-px bg-gradient-to-b from-white/40 to-transparent"></span>
  </div>
</section>

<style>
  .hero-sun-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: -1;
  }

  .hero-sunrise {
    position: absolute;
    left: 50%;
    bottom: 18%;
    transform: translate(-50%, 0);
    width: min(100vw, clamp(280px, 92vw, 720px));
    aspect-ratio: 1 / 1;
    pointer-events: none;
  }

  .hero-sunrise-atmosphere {
    position: absolute;
    inset: -85%;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(252, 201, 122, 0.35) 0%,
      rgba(245, 176, 66, 0.18) 35%,
      rgba(245, 176, 66, 0.06) 60%,
      transparent 82%
    );
    filter: blur(55px);
    z-index: 0;
  }

  .hero-sunrise-glow {
    position: absolute;
    inset: -30%;
    border-radius: 50%;
    background: radial-gradient(circle at center, rgba(252, 201, 122, 0.55) 0%, rgba(245, 176, 66, 0.25) 40%, transparent 72%);
    filter: blur(24px);
    animation: glow-pulse 6s ease-in-out infinite;
    z-index: 1;
  }

  .hero-sunrise-disc {
    position: absolute;
    inset: 18%;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #ffe1a8 0%, #f5b042 55%, #d8902a 100%);
    box-shadow: 0 0 80px 20px rgba(245, 176, 66, 0.5);
    z-index: 2;
  }

  .hero-sunrise-ring {
    position: absolute;
    inset: 16%;
    border-radius: 50%;
    border: 2px solid rgba(252, 201, 122, 0.6);
    box-shadow: inset 0 0 40px rgba(245, 176, 66, 0.4);
    z-index: 3;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-sunrise-glow {
      animation: none !important;
    }
  }
</style>

