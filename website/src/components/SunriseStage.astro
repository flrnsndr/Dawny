---
---

<div data-sunrise-stage class="sunrise-stage">
  <div class="sunrise-sky-pin" aria-hidden="true">
    <div class="sunrise-sky">
      <div class="sunrise-sky-night"></div>
      <div class="sunrise-sky-day"></div>

      <svg
        class="sunrise-sky-stars"
        viewBox="0 0 1440 900"
        preserveAspectRatio="xMidYMid slice"
        aria-hidden="true"
      >
        <g fill="white">
          <circle cx="120" cy="110" r="1.2" opacity="0.85"><animate attributeName="opacity" values="0.2;1;0.2" dur="3.4s" repeatCount="indefinite"/></circle>
          <circle cx="280" cy="180" r="0.9" opacity="0.6"><animate attributeName="opacity" values="0.1;0.8;0.1" dur="4.1s" begin="0.6s" repeatCount="indefinite"/></circle>
          <circle cx="430" cy="80" r="1.4" opacity="0.9"><animate attributeName="opacity" values="0.3;1;0.3" dur="2.8s" begin="1.2s" repeatCount="indefinite"/></circle>
          <circle cx="640" cy="160" r="0.7" opacity="0.5"><animate attributeName="opacity" values="0.1;0.7;0.1" dur="3.6s" begin="0.3s" repeatCount="indefinite"/></circle>
          <circle cx="880" cy="100" r="1.1" opacity="0.8"><animate attributeName="opacity" values="0.2;1;0.2" dur="3.0s" begin="1.5s" repeatCount="indefinite"/></circle>
          <circle cx="1080" cy="220" r="0.8" opacity="0.55"><animate attributeName="opacity" values="0.1;0.7;0.1" dur="3.8s" begin="0.9s" repeatCount="indefinite"/></circle>
          <circle cx="1280" cy="120" r="1.3" opacity="0.85"><animate attributeName="opacity" values="0.3;1;0.3" dur="2.6s" begin="0.4s" repeatCount="indefinite"/></circle>
          <circle cx="1340" cy="260" r="0.6" opacity="0.45"><animate attributeName="opacity" values="0.1;0.6;0.1" dur="4.4s" begin="1.8s" repeatCount="indefinite"/></circle>
          <circle cx="200" cy="320" r="0.7" opacity="0.5"><animate attributeName="opacity" values="0.1;0.7;0.1" dur="3.2s" begin="1.0s" repeatCount="indefinite"/></circle>
          <circle cx="780" cy="300" r="0.6" opacity="0.4"><animate attributeName="opacity" values="0.1;0.6;0.1" dur="4.0s" begin="0.2s" repeatCount="indefinite"/></circle>
        </g>
      </svg>
    </div>
  </div>

  <slot />
</div>

<style>
  .sunrise-stage {
    --dawn-progress: 0;
    position: relative;
    isolation: isolate;
    /* Clippt Sun-Halos, die ansonsten in Header / Reset-Sektion leaken würden,
       erlaubt aber freies Überlappen zwischen Hero und Manifest innerhalb. */
    overflow: clip;
  }

  .sunrise-sky-pin {
    position: absolute;
    inset: 0;
    z-index: -10;
    pointer-events: none;
    overflow: clip;
  }

  .sunrise-sky {
    position: sticky;
    top: 0;
    height: 100dvh;
    width: 100%;
    overflow: hidden;
  }

  .sunrise-sky-night,
  .sunrise-sky-day,
  .sunrise-sky-stars {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .sunrise-sky-night {
    background:
      radial-gradient(ellipse at 50% 110%, rgba(245, 176, 66, 0.18) 0%, transparent 55%),
      radial-gradient(ellipse at 50% 90%, rgba(42, 74, 127, 0.55) 0%, transparent 60%),
      linear-gradient(180deg, #050d20 0%, #0b1733 55%, #142547 100%);
  }

  .sunrise-sky-day {
    background:
      radial-gradient(ellipse at 50% 90%, rgba(252, 201, 122, 0.45) 0%, transparent 55%),
      linear-gradient(180deg, #f5b042 0%, #fcc97a 35%, #bedde6 75%, #e8f4f7 100%);
    opacity: var(--dawn-progress, 0);
  }

  .sunrise-sky-stars {
    opacity: calc(1 - var(--dawn-progress, 0));
  }
</style>

<script>
  const stage = document.querySelector<HTMLElement>("[data-sunrise-stage]");
  if (stage) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (reduce) {
      stage.style.setProperty("--dawn-progress", "0");
    } else {
      let raf = 0;
      const update = () => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          const rect = stage.getBoundingClientRect();
          const total = Math.max(1, stage.offsetHeight - window.innerHeight);
          const progress = Math.max(0, Math.min(1, -rect.top / total));
          stage.style.setProperty("--dawn-progress", progress.toFixed(4));
        });
      };
      window.addEventListener("scroll", update, { passive: true });
      window.addEventListener("resize", update);
    }
  }
</script>
