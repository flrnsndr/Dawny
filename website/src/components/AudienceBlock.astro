---
import { type Lang, getDict } from "@/i18n";
import SunMark from "@/components/SunMark.astro";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const dict = getDict(lang);
---

<section
  id="audience"
  class="relative bg-[#eef2f7] text-[var(--color-ink)] py-32 sm:py-44"
>
  <SunMark />

  <div class="container-narrow relative z-10">
    <p class="reveal text-xs font-medium uppercase tracking-[0.18em] text-[var(--color-ink-soft)]/70 mb-6">
      <span class="inline-block h-px w-8 bg-[var(--color-ink-soft)]/40 align-middle mr-3"></span>
      {dict.audience.eyebrow}
    </p>

    <h2 class="reveal text-display text-[clamp(2rem,5vw,3.75rem)] mb-12">
      {dict.audience.title}
    </h2>

    <ul class="audience-list">
      {dict.audience.items.map((item, i) => (
        <li class="reveal" style={`transition-delay: ${i * 90}ms`}>
          <span class="audience-bullet" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4">
              <path d="M5 12l5 5L20 7"/>
            </svg>
          </span>
          <span>{item}</span>
        </li>
      ))}
    </ul>

    <p class="reveal mt-14 font-sans text-base text-[var(--color-ink-soft)] text-[1.15rem] leading-relaxed border-l-2 border-[var(--color-dawn)] pl-6">
      {dict.audience.footnote}
    </p>
  </div>
</section>

<style>
  .audience-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .audience-list li {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    font-size: clamp(1.125rem, 1.6vw, 1.4rem);
    color: var(--color-ink);
    line-height: 1.45;
  }

  .audience-bullet {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-dawn) 0%, var(--color-dawn-soft) 100%);
    color: var(--color-night);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 6px 16px -8px rgba(245, 176, 66, 0.6);
    margin-top: 0.2rem;
  }
</style>
